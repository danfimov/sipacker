{
  "name": "sipacker",
  "version": "2.0.0",
  "description": "Online editor of questions for SiGame",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@react-hook/size": "^2.1.2",
    "@reduxjs/toolkit": "^2.11.2",
    "checkerboardjs": "^1.1.0",
    "classnames": "^2.5.1",
    "compressorjs": "^1.1.1",
    "content-type": "^1.0.4",
    "dayjs": "^1.11.20",
    "decimal.js": "^10.3.1",
    "dexie": "^4.4.2",
    "file-saver": "^2.0.5",
    "filesize": "^11.0.15",
    "formik": "^2.4.9",
    "jszip": "^3.10.1",
    "just-clone": "^3.2.1",
    "nanoid": "^5.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^11.4.2",
    "react-icons": "^5.6.0",
    "react-merge-refs": "^1.1.0",
    "react-redux": "^7.2.6",
    "react-router": "^7.14.0",
    "redux": "^4.1.2",
    "spark-md5": "^3.0.2",
    "transliteration": "^2.2.0",
    "uuid": "^3.4.0",
    "waveformer": "^1.0.4",
    "workbox-cacheable-response": "^6.4.2",
    "workbox-core": "^6.4.2",
    "workbox-expiration": "^6.4.2",
    "workbox-precaching": "^6.4.2",
    "workbox-routing": "^6.4.2",
    "workbox-strategies": "^6.4.2",
