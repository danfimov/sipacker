    "xml-js": "^1.6.11",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^8.8.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "http-server": "^14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.49.9",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "netlify-build": "vite build && echo \"/* /index.html 200\" > build/_redirects",
    "ghp-build": "VITE_BASE_PATH=/SIPacker vite build",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{js,jsx,scss,css}\"",
    "lint": "eslint src --ext .js,.jsx --fix"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{scss,css}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
