# Vite Environment Variables
# Copy this file to .env for local development

# Base public path when served in development or production
# Use "/" for root domain, or "/subdirectory" for subdirectory deployment
VITE_BASE_PATH=/

# Application metadata (optional, defaults in vite.config.js)
VITE_APP_TITLE=SIPacker
VITE_APP_DESCRIPTION=Online editor of questions for Sigmame
